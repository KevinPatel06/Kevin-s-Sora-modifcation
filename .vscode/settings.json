{
  "files.associations": {
    "*.entitlements": "xml",
    "*.plist": "xml",
    "*.pbxproj": "plaintext",
    "*.xcscheme": "xml"
  },
  "files.exclude": {
    "**/build": true,
    "**/DerivedData": true,
    "**/*.xcodeproj/xcuserdata": true
  },
  "search.exclude": {
    "**/build": true,
    "**/DerivedData": true,
    "**/assets": true,
    "**/*.pbxproj": true
  },
  "files.trimTrailingWhitespace": true,
  "[swift]": {
    "editor.tabSize": 4,
    "editor.insertSpaces": true
  },
  "yaml.schemas": {
    "https://json.schemastore.org/github-workflow.json": ".github/workflows/*.yml"
  }
}
